# Botanica Obscura — sous-dossier OVH
Options -Indexes

<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|json)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
</IfModule>

<FilesMatch "\.(js|mjs|css|html|json)$">
  Allow from all
  Satisfy Any
</FilesMatch>
